{
  "name": "paper-collection-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --exclude tests/integration",
    "test:watch": "vitest --exclude tests/integration",
    "test:integration": "node --env-file-if-exists=.env.test --env-file-if-exists=.env.local --env-file-if-exists=.env node_modules/vitest/dist/cli.js run tests/integration",
    "test:e2e": "playwright test",
    "db:seed": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env prisma/seed.ts",
    "ingest": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env scripts/ingest.ts",
    "validate:candidates": "tsx scripts/validate-candidates.ts",
    "validate:evaluations": "tsx scripts/validate-evaluations.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env node_modules/prisma/build/index.js migrate dev",
    "prisma:studio": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env node_modules/prisma/build/index.js studio",
    "postinstall": "prisma generate || true"
  },
  "prisma": {
    "seed": "tsx --env-file-if-exists=.env.local --env-file-if-exists=.env prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-xml-parser": "^5.7.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.5",
    "pino": "^10.3.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.5",
    "eslint-config-prettier": "^10.1.8",
    "fastest-levenshtein": "^1.0.16",
    "jsdom": "^29.1.1",
    "p-limit": "^7.3.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
