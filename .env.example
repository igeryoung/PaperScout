# Postgres connection string for Prisma + the app
# Matches docker-compose.yml defaults
DATABASE_URL="postgresql://paperscout:paperscout@localhost:5432/paperscout?schema=public"

# Anthropic API key (Phase 0.5 PoC and onwards)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Logging level: trace | debug | info | warn | error
LOG_LEVEL="info"
